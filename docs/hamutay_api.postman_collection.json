            {
              "name": "Marcar como pagada",
              "request": {
                "method": "PATCH",
                "header": [{ "key": "Authorization", "value": "Bearer {{platform_token}}" }],
                "url": {
                  "raw": "{{base_url}}/platform/invoices/{{invoice_id}}/mark-paid?payment_reference=TXN-123456&payment_method=transferencia",
                  "host": ["{{base_url}}"],
                  "path": ["platform", "invoices", "{{invoice_id}}", "mark-paid"],
                  "query": [
                    { "key": "payment_reference", "value": "TXN-123456" },
                    { "key": "payment_method",    "value": "transferencia" }
                  ]
                }
              },
              "response": []
            },
