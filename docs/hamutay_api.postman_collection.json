                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"notes\": \"Pago pendiente de confirmacion\",\n  \"payment_method\": \"yape\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": "{{base_url}}/platform/invoices/{{invoice_id}}"
