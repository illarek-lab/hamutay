            {
              "name": "Listar facturas",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{platform_token}}" }],
                "url": {
                  "raw": "{{base_url}}/platform/invoices",
                  "host": ["{{base_url}}"],
                  "path": ["platform", "invoices"],
                  "query": [
                    { "key": "school_id", "value": "{{school_id}}", "disabled": true }
                  ]
                }
              },
              "response": []
