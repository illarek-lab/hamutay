  "variable": [
    { "key": "base_url",         "value": "http://localhost:8000", "type": "string" },
    { "key": "platform_token",   "value": "",                      "type": "string" },
    { "key": "platform_user_id", "value": "",                      "type": "string" },
    { "key": "plan_id",          "value": "",                      "type": "string" },
    { "key": "module_id",        "value": "",                      "type": "string" },
