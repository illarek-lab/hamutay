  ],
  "item": [
    {
      "name": "🔧 Platform",
      "item": [
        {
          "name": "Auth",
          "item": [
            {
              "name": "Login",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "type": "text/javascript",
                    "exec": [
                      "var res = pm.response.json();",
                      "if (res.access_token) {",
                      "    pm.collectionVariables.set('platform_token', res.access_token);",
                      "}"
                    ]
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [{ "key": "Content-Type", "value": "application/json" }],
                "body": {
                  "mode": "raw",
                  "raw": "{\n  \"email\": \"admin@hamutay.com\",\n  \"password\": \"Admin1234!\"\n}",
                  "options": { "raw": { "language": "json" } }
                },
                "url": "{{base_url}}/platform/auth/login"
              },
              "response": []
            },
            {
              "name": "Me",
              "request": {
                "method": "GET",
                "header": [{ "key": "Authorization", "value": "Bearer {{platform_token}}" }],
                "url": "{{base_url}}/platform/auth/me"
              },
              "response": []
            }
          ]
        },
